#!/bin/sh
# Check if any blog posts changed in the commits being pushed.
# If so, publish them to the AT Protocol via Sequoia.

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — diff against the initial commit
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$range" | grep -q "^src/lib/posts/.*\.md$"; then
    echo "Blog post changes detected. Running sequoia publish..."
    npx sequoia publish
    exit $?
  fi
done
